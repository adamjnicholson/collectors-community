{
    "private": true,
    "name": "remix-app-template",
    "description": "",
    "license": "",
    "scripts": {
        "build:css": "tailwindcss --output ./app/styles/tailwind.css --config ./tailwind.js --minify",
        "build:remix": "remix build",
        "build": "yarn run build:css & build:remix",
        "db:migrate": "npx prisma migrate dev",
        "dev:css": "tailwindcss --output ./app/styles/tailwind.css --config ./tailwind.js --watch",
        "dev:remix": "remix watch",
        "dev:server": "cross-env NODE_ENV=development node server/index.js",
        "dev": "yarn run dev:remix & yarn run dev:server & yarn run dev:css",
        "format:all": "yarn prettier --write .",
        "lint": "eslint --ext .ts,.tsx .",
        "prod:start": "cross-env NODE_ENV=production node server/index.js",
        "postinstall": "remix setup node",
        "types": "tsc"
    },
    "dependencies": {
        "@fortawesome/fontawesome-svg-core": "^1.2.36",
        "@fortawesome/free-brands-svg-icons": "^5.15.4",
        "@fortawesome/free-regular-svg-icons": "^5.15.4",
        "@fortawesome/free-solid-svg-icons": "^5.15.4",
        "@fortawesome/react-fontawesome": "^0.1.16",
        "@prisma/client": "^3.4.1",
        "@remix-run/express": "^1.0.6",
        "@remix-run/react": "^1.0.6",
        "compression": "^1.7.4",
        "cross-env": "^7.0.3",
        "express": "^4.17.1",
        "morgan": "^1.10.0",
        "react": "^17.0.2",
        "react-dom": "^17.0.2",
        "react-router-dom": "6.0.0-beta.8",
        "remix": "^1.0.6",
        "zod": "^3.11.6"
    },
    "devDependencies": {
        "@remix-run/dev": "^1.0.6",
        "@types/node": "^16.11.6",
        "@types/react": "^17.0.24",
        "@types/react-dom": "^17.0.9",
        "@typescript-eslint/eslint-plugin": "^5.4.0",
        "@typescript-eslint/parser": "^5.4.0",
        "eslint": "^8.2.0",
        "eslint-config-airbnb": "^19.0.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-import-resolver-typescript": "^2.5.0",
        "eslint-plugin-import": "^2.25.3",
        "eslint-plugin-jsx-a11y": "^6.5.1",
        "eslint-plugin-react": "^7.27.0",
        "eslint-plugin-react-hooks": "^4.3.0",
        "prettier": "^2.4.1",
        "prisma": "3.4.1",
        "tailwindcss": "^2.2.19",
        "ts-node": "^10.4.0",
        "typescript": "^4.4.4"
    },
    "engines": {
        "node": ">=14"
    },
    "sideEffects": false
}
